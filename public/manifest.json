{
    "manifest_version": 3,
    "name": "gh-plus",
    "version": "1.1",
    "description": "Enhance GitHub PR page",
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "https://api.github.com/*"
    ],
    "options_page": "options.html",
    "content_scripts": [
        {
            "js": [
                "main.js"
            ],
            "css": [
                "main.css"
            ],
            "matches": [
                "https://github.com/*/*/pulls*"
            ]
        }
    ]
}